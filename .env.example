# ─── Database ───
# PostgreSQL connection string (Neon, Railway, or local Docker)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── BetterAuth ───
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
# URL where the app is running
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# ─── Cloudflare R2 ───
# Account ID from your R2 dashboard subdomain
R2_ACCOUNT_ID="your-account-id-here"
# R2 API credentials (create from R2 dashboard → API Tokens)
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
# Bucket name (created automatically on first upload if it doesn't exist)
R2_BUCKET="vidback"
